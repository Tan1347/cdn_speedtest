<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="120dp"
            android:layout_height="68dp"
            android:scaleType="centerCrop"
            android:background="@color/thumbnail_bg"
            android:contentDescription="视频封面" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <EditText
                android:id="@+id/etFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:inputType="text"
                android:singleLine="true"
                android:background="@android:drawable/edit_text"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvResolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@color/divider" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="保存格式"
        android:textSize="14sp"
        android:textColor="@color/text_secondary" />

    <RadioGroup
        android:id="@+id/rgFormat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <RadioButton
            android:id="@+id/rbOriginal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="原格式 (.ts)"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <RadioButton
            android:id="@+id/rbMp4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MP4 容器"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <RadioButton
            android:id="@+id/rbH264"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="H.264 编码 (.mp4)"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <RadioButton
            android:id="@+id/rbHevc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="H.265/HEVC 编码 (.mp4)"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <RadioButton
            android:id="@+id/rbAv1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AV1 编码 (.mp4)"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />
    </RadioGroup>
</LinearLayout>
